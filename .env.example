# Environment Configuration
# Copy this to .env and modify as needed

# Database
DATABASE_URL=sqlite:///./visiting_cards.db

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# CORS
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO

# OCR
OCR_LANGUAGE=en
OCR_USE_GPU=false

# Upload
UPLOAD_DIR=backend/uploads
MAX_UPLOAD_SIZE=10485760

# Application
DEBUG=false
